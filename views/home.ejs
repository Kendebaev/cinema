<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cinema Tickets - Home</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .search-results {
      margin-top: 30px;
      padding: 20px;
      border: 1px solid #ddd;
      border-radius: 5px;
    }

    .movie-item {
      padding: 15px;
      margin: 10px 0;
      border: 1px solid #ccc;
      border-radius: 5px;
      background-color: #f9f9f9;
    }

    .movie-title {
      font-weight: bold;
      font-size: 1.1em;
      color: #333;
    }

    .movie-info {
      margin-top: 5px;
      color: #666;
      font-size: 0.95em;
    }

    .no-results {
      color: #999;
      font-style: italic;
    }

    .api-links {
      margin-top: 30px;
      padding: 20px;
      background-color: #f0f0f0;
      border-radius: 5px;
    }

    .api-links h3 {
      margin-top: 0;
      color: #333;
    }

    .api-links ul {
      list-style-type: none;
      padding: 0;
    }

    .api-links li {
      padding: 8px 0;
    }

    .api-links a {
      color: #007bff;
      text-decoration: none;
    }

    .api-links a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <%- include('partials/header') %>
    <main>
      <h2>Welcome to Cinema Tickets</h2>
      <p>Buy your movie tickets online easily. Click "Buy Tickets" to book your seats now!</p>

      <section>
        <h3>Search for Movies</h3>
        <form id="searchForm">
          <input type="text" id="searchInput" placeholder="Search for a movie..." required>
          <button type="submit">Search</button>
        </form>
        <div id="searchResults" class="search-results" style="display: none;"></div>
      </section>

      <section class="api-links">
        <h3>API Test Links</h3>
        <p>Test the API endpoints directly:</p>
        <ul>
          <li><a href="/api/seats" target="_blank">GET /api/seats - Get all rooms</a></li>
          <li><a href="/api/seats/room1" target="_blank">GET /api/seats/room1 - Get room 1</a></li>
          <li><a href="/api/info" target="_blank">GET /api/info - Get API info</a></li>
        </ul>
      </section>
    </main>

    <script>
      const searchForm = document.getElementById('searchForm');
      const searchInput = document.getElementById('searchInput');
      const searchResults = document.getElementById('searchResults');

      searchForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const query = searchInput.value.trim();

        if (!query) {
          alert('Please enter a search query');
          return;
        }

        try {
          const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
          const data = await response.json();

          if (response.ok) {
            if (data.length === 0) {
              searchResults.innerHTML = `<p class="no-results">No movies found matching "${query}"</p>`;
            } else {
              let html = `<h3>Search Results for "${query}"</h3>`;
              data.forEach(movie => {
                html += `
                <div class="movie-item">
                  <div class="movie-title">${movie.title}</div>
                  <div class="movie-info"><strong>Genre:</strong> ${movie.genre}</div>
                  ${movie.description ? `<div class="movie-info"><strong>Description:</strong> ${movie.description}</div>` : ''}
                  ${movie.duration ? `<div class="movie-info"><strong>Duration:</strong> ${movie.duration} min</div>` : ''}
                  ${movie.releaseDate ? `<div class="movie-info"><strong>Release Date:</strong> ${movie.releaseDate}</div>` : ''}
                  ${movie.rating ? `<div class="movie-info"><strong>Rating:</strong> ${movie.rating}/10</div>` : ''}
                </div>
              `;
              });
              searchResults.innerHTML = html;
            }
            searchResults.style.display = 'block';
          } else {
            searchResults.innerHTML = `<p class="no-results">Error: ${data.error || 'Unable to search'}</p>`;
            searchResults.style.display = 'block';
          }
        } catch (error) {
          searchResults.innerHTML = `<p class="no-results">Error: ${error.message}</p>`;
          searchResults.style.display = 'block';
        }
      });
    </script>
</body>

</html>