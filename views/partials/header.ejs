<header>
    <h1>Cinema Tickets Buy Site</h1>
</header>
<nav>
    <a href="/">Home</a>
    <a href="/search?q=movie">Search</a>
    <a href="/movies">All Movies</a>
    <a href="/buy">Buy Tickets</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <% if (typeof user !== 'undefined' && user) { %>
        <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard" style="color: #ffd700;">⚡ Admin</a>
        <% } %>
        <div class="dropdown" style="display: inline-block; position: relative;">
            <span class="dropbtn" style="color: #00ff00; margin-left: 1rem; cursor: pointer;">Hello, <%= user.username
                    %> ▼</span>
            <div class="dropdown-content">
                <a href="/my-bookings">My Bookings</a>
                <a href="/logout">Logout</a>
                <form action="/delete-account" method="POST"
                    onsubmit="return confirm('Are you sure you want to delete your account? This cannot be undone.');"
                    style="margin: 0; padding: 0;">
                    <button type="submit"
                        style="background: none; border: none; color: white; width: 100%; text-align: left; padding: 12px 16px; cursor: pointer; font-size: 16px; font-family: inherit;">Delete
                        Account</button>
                </form>
            </div>
        </div>
        <% } else { %>
            <a href="/login">Login</a>
            <a href="/register">Register</a>
            <% } %>
</nav>