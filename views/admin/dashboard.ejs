<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Cinema</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .admin-container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 20px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .admin-header h2 {
            color: #ffd700;
            margin: 0;
        }

        .alert {
            padding: 12px 20px;
            border-radius: 6px;
            margin-bottom: 1.5rem;
            font-weight: bold;
        }

        .alert-success {
            background: rgba(0, 255, 0, 0.15);
            color: #00ff00;
            border: 1px solid rgba(0, 255, 0, 0.4);
        }

        .alert-error {
            background: rgba(255, 0, 0, 0.15);
            color: #ff6666;
            border: 1px solid rgba(255, 0, 0, 0.4);
        }

        /* Add Movie Form */
        .add-movie-section {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 215, 0, 0.3);
            border-radius: 8px;
            padding: 2rem;
            margin-bottom: 2rem;
        }

        .add-movie-section h3 {
            color: #ffd700;
            margin-top: 0;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
        }

        .form-row.full {
            grid-template-columns: 1fr;
        }

        .form-group {
            margin-bottom: 10px;
        }

        .form-group label {
            display: block;
            color: #ffd700;
            margin-bottom: 5px;
            font-weight: bold;
            font-size: 0.9em;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 2px solid rgba(255, 215, 0, 0.3);
            background: rgba(0, 0, 0, 0.3);
            color: white;
            border-radius: 4px;
            font-size: 0.95em;
            box-sizing: border-box;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            box-shadow: 0 0 8px rgba(255, 215, 0, 0.4);
        }

        .btn-admin {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            font-size: 0.95em;
            transition: all 0.3s;
        }

        .btn-add {
            background: #ffd700;
            color: #000;
        }

        .btn-add:hover {
            background: #ffed4a;
            transform: scale(1.02);
        }

        .btn-edit {
            background: #ff6600;
            color: white;
            padding: 6px 14px;
            font-size: 0.85em;
        }

        .btn-edit:hover {
            background: #ff8533;
        }

        .btn-delete {
            background: #cc0000;
            color: white;
            padding: 6px 14px;
            font-size: 0.85em;
        }

        .btn-delete:hover {
            background: #ff3333;
        }

        .btn-save {
            background: #00aa00;
            color: white;
            padding: 6px 14px;
            font-size: 0.85em;
        }

        .btn-save:hover {
            background: #00cc00;
        }

        .btn-cancel {
            background: #666;
            color: white;
            padding: 6px 14px;
            font-size: 0.85em;
        }

        .btn-cancel:hover {
            background: #888;
        }

        /* Movies Table */
        .movies-table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid rgba(255, 215, 0, 0.2);
            border-radius: 8px;
            overflow: hidden;
        }

        .movies-table th {
            background: rgba(255, 215, 0, 0.15);
            color: #ffd700;
            padding: 12px 15px;
            text-align: left;
            font-size: 0.9em;
            border-bottom: 2px solid rgba(255, 215, 0, 0.3);
        }

        .movies-table td {
            padding: 10px 15px;
            color: #ddd;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 0.9em;
        }

        .movies-table tr:hover {
            background: rgba(255, 215, 0, 0.05);
        }

        .actions-cell {
            white-space: nowrap;
        }

        .actions-cell form {
            display: inline-block;
            margin: 0 3px;
        }

        /* Edit form row */
        .edit-row {
            display: none;
        }

        .edit-row.active {
            display: table-row;
        }

        .edit-row td {
            background: rgba(255, 215, 0, 0.08);
        }

        .edit-row input,
        .edit-row textarea {
            width: 100%;
            padding: 6px;
            border: 1px solid rgba(255, 215, 0, 0.3);
            background: rgba(0, 0, 0, 0.3);
            color: white;
            border-radius: 3px;
            font-size: 0.85em;
            box-sizing: border-box;
        }

        .edit-row textarea {
            resize: vertical;
            min-height: 50px;
        }

        .no-movies {
            text-align: center;
            color: #999;
            padding: 30px;
            font-style: italic;
        }

        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .movies-table {
                font-size: 0.8em;
            }
        }
    </style>
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <div class="admin-container">
                <div class="admin-header">
                    <h2>⚡ Admin Dashboard</h2>
                    <span style="color: #ffd700;">Managing <%= movies.length %> movie(s)</span>
                </div>

                <% if (success) { %>
                    <div class="alert alert-success">
                        <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-error">
                                <%= error %>
                            </div>
                            <% } %>

                                <!-- Add Movie Form -->
                                <div class="add-movie-section">
                                    <h3>➕ Add New Movie</h3>
                                    <form action="/admin/movies" method="POST">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Title *</label>
                                                <input type="text" name="title" placeholder="Movie title" required
                                                    maxlength="200">
                                            </div>
                                            <div class="form-group">
                                                <label>Genre *</label>
                                                <input type="text" name="genre" placeholder="e.g. Action, Comedy"
                                                    required maxlength="100">
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Duration (minutes)</label>
                                                <input type="number" name="duration" placeholder="e.g. 120" min="1"
                                                    max="600">
                                            </div>
                                            <div class="form-group">
                                                <label>Release Date</label>
                                                <input type="text" name="releaseDate" placeholder="e.g. 2024">
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Rating (0-10)</label>
                                                <input type="number" name="rating" placeholder="e.g. 8.5" min="0"
                                                    max="10" step="0.1">
                                            </div>
                                            <div class="form-group">
                                                <label>Description</label>
                                                <textarea name="description" placeholder="Movie description..."
                                                    maxlength="1000"></textarea>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-admin btn-add">➕ Add Movie</button>
                                    </form>
                                </div>

                                <!-- Movies Table -->
                                <% if (movies && movies.length> 0) { %>
                                    <table class="movies-table">
                                        <thead>
                                            <tr>
                                                <th>Title</th>
                                                <th>Genre</th>
                                                <th>Duration</th>
                                                <th>Year</th>
                                                <th>Rating</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% movies.forEach((movie, index)=> { %>
                                                <!-- Display Row -->
                                                <tr id="display-<%= movie._id %>">
                                                    <td><strong>
                                                            <%= movie.title %>
                                                        </strong></td>
                                                    <td>
                                                        <%= movie.genre %>
                                                    </td>
                                                    <td>
                                                        <%= movie.duration ? movie.duration + ' min' : '-' %>
                                                    </td>
                                                    <td>
                                                        <%= movie.releaseDate || '-' %>
                                                    </td>
                                                    <td>
                                                        <%= movie.rating ? '⭐ ' + movie.rating + '/10' : '-' %>
                                                    </td>
                                                    <td class="actions-cell">
                                                        <button class="btn-admin btn-edit"
                                                            onclick="toggleEdit('<%= movie._id %>')">✏️ Edit</button>
                                                        <form action="/admin/movies/<%= movie._id %>/delete"
                                                            method="POST"
                                                            onsubmit="return confirm('Delete this movie?');">
                                                            <button type="submit" class="btn-admin btn-delete">🗑️
                                                                Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <!-- Edit Row (hidden by default) -->
                                                <tr id="edit-<%= movie._id %>" class="edit-row">
                                                    <td colspan="6">
                                                        <form action="/admin/movies/<%= movie._id %>/update"
                                                            method="POST">
                                                            <div class="form-row">
                                                                <div class="form-group">
                                                                    <label>Title</label>
                                                                    <input type="text" name="title"
                                                                        value="<%= movie.title %>" required>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label>Genre</label>
                                                                    <input type="text" name="genre"
                                                                        value="<%= movie.genre %>" required>
                                                                </div>
                                                            </div>
                                                            <div class="form-row">
                                                                <div class="form-group">
                                                                    <label>Duration</label>
                                                                    <input type="number" name="duration"
                                                                        value="<%= movie.duration || '' %>">
                                                                </div>
                                                                <div class="form-group">
                                                                    <label>Release Date</label>
                                                                    <input type="text" name="releaseDate"
                                                                        value="<%= movie.releaseDate || '' %>">
                                                                </div>
                                                            </div>
                                                            <div class="form-row">
                                                                <div class="form-group">
                                                                    <label>Rating</label>
                                                                    <input type="number" name="rating"
                                                                        value="<%= movie.rating || '' %>" min="0"
                                                                        max="10" step="0.1">
                                                                </div>
                                                                <div class="form-group">
                                                                    <label>Description</label>
                                                                    <textarea
                                                                        name="description"><%= movie.description || '' %></textarea>
                                                                </div>
                                                            </div>
                                                            <button type="submit" class="btn-admin btn-save">💾
                                                                Save</button>
                                                            <button type="button" class="btn-admin btn-cancel"
                                                                onclick="toggleEdit('<%= movie._id %>')">Cancel</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                        </tbody>
                                    </table>
                                    <% } else { %>
                                        <div class="no-movies">
                                            <p>No movies in the database. Add your first movie above!</p>
                                        </div>
                                        <% } %>
            </div>
        </main>

        <script>
            function toggleEdit(movieId) {
                const displayRow = document.getElementById('display-' + movieId);
                const editRow = document.getElementById('edit-' + movieId);
                editRow.classList.toggle('active');
                displayRow.style.display = editRow.classList.contains('active') ? 'none' : '';
            }
        </script>
</body>

</html>