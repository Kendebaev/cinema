<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cinema Tickets - Search</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .search-results {
      margin-top: 30px;
      padding: 20px;
      border: 1px solid #ddd;
      border-radius: 5px;
    }

    .movie-item {
      padding: 15px;
      margin: 10px 0;
      border: 1px solid #ccc;
      border-radius: 5px;
      background-color: #f9f9f9;
    }

    .movie-title {
      font-weight: bold;
      font-size: 1.1em;
      color: #333;
    }

    .movie-info {
      margin-top: 5px;
      color: #666;
      font-size: 0.95em;
    }

    .no-results {
      color: #999;
      font-style: italic;
    }
  </style>
</head>

<body>
  <%- include('partials/header') %>
    <main>
      <h2>Search Results</h2>

      <section>
        <h3>Search for Movies</h3>
        <form id="searchForm">
          <input type="text" id="searchInput" placeholder="Search for a movie..." value="<%= query %>" required>
          <button type="submit">Search</button>
        </form>
        <div id="searchResults" class="search-results"></div>
      </section>
    </main>

    <script>
      const searchForm = document.getElementById('searchForm');
      const searchInput = document.getElementById('searchInput');
      const searchResults = document.getElementById('searchResults');

      // Perform search on page load with initial query
      function performSearch(query) {
        if (!query.trim()) {
          searchResults.innerHTML = '<p class="no-results">Please enter a search query</p>';
          return;
        }

        fetch(`/api/search?q=${encodeURIComponent(query)}`)
          .then(response => response.json())
          .then(data => {
            if (data.length === 0) {
              searchResults.innerHTML = `<p class="no-results">No movies found matching "${query}"</p>`;
            } else {
              let html = `<h3>Search Results for "${query}"</h3>`;
              data.forEach(movie => {
                html += `
                <div class="movie-item">
                  <div class="movie-title">${movie.title}</div>
                  <div class="movie-info"><strong>Genre:</strong> ${movie.genre}</div>
                  ${movie.description ? `<div class="movie-info"><strong>Description:</strong> ${movie.description}</div>` : ''}
                  ${movie.duration ? `<div class="movie-info"><strong>Duration:</strong> ${movie.duration} min</div>` : ''}
                  ${movie.releaseDate ? `<div class="movie-info"><strong>Release Date:</strong> ${movie.releaseDate}</div>` : ''}
                  ${movie.rating ? `<div class="movie-info"><strong>Rating:</strong> ${movie.rating}/10</div>` : ''}
                </div>
              `;
              });
              searchResults.innerHTML = html;
            }
          })
          .catch(error => {
            searchResults.innerHTML = `<p class="no-results">Error: ${error.message}</p>`;
          });
      }

      // Handle form submission
      searchForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const query = searchInput.value.trim();
        performSearch(query);
      });

      // Initial search on page load
      window.addEventListener('load', () => {
        const initialQuery = '<%= query %>';
        if (initialQuery) {
          performSearch(initialQuery);
        }
      });
    </script>
</body>

</html>